NODE_ENV=production
PORT=3000
API_PREFIX=api
API_VERSION=1
API_HOST_PORT=3000

POSTGRES_DB=nestjs_starter
POSTGRES_USER=nestjs_app
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# POSTGRES_PASSWORD and DATABASE_URL must use the same database credentials.
DATABASE_URL=postgresql://nestjs_app:replace-with-a-strong-database-password@postgres:5432/nestjs_starter?schema=public

JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-32-character-secret
JWT_REFRESH_EXPIRES_IN=7d

THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
AUTH_THROTTLE_TTL_MS=60000
AUTH_THROTTLE_LIMIT=10

TRUST_PROXY=false
